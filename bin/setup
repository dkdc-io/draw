#!/usr/bin/env bash
set -euo pipefail

# Install rustup and uv if not already present.

if ! command -v rustup &>/dev/null; then
    echo "Installing rustup..."
    curl --proto '=https' --tlsv1.2 -LsSf https://sh.rustup.rs | sh -s -- -y
    . "$HOME/.cargo/env"
fi

if ! command -v uv &>/dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

if ! command -v wasm-pack &>/dev/null; then
    echo "Installing wasm-pack..."
    cargo install wasm-pack
fi

# Install GTK/WebKit dev libs for the desktop app (draw-app) on Linux
if [[ "$(uname)" == "Linux" ]] && command -v apt-get &>/dev/null; then
    if ! pkg-config --exists gtk+-3.0 webkit2gtk-4.1 2>/dev/null; then
        echo "Installing GTK/WebKit dev libraries..."
        sudo apt-get update -qq
        sudo apt-get install -y -qq libgtk-3-dev libwebkit2gtk-4.1-dev libayatana-appindicator3-dev
    fi
fi

echo "Setup complete!"
