#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")/.."

# draw-app requires GTK/glib (Linux system dep)
# draw-webapp embeds WASM build artifacts (requires bin/build-wasm first)
# Both are excluded from CI checks — only core + wasm + cli are checked
EXCLUDE="--exclude dkdc-draw-app --exclude dkdc-draw-webapp"

echo "Checking Rust formatting..."
cargo fmt -- --check

echo "Running clippy..."
cargo clippy --workspace $EXCLUDE -- -D warnings

echo "Running Rust tests..."
cargo test --workspace $EXCLUDE

echo "Rust checks passed!"
